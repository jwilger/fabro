+/// Graph layout direction.
+#[derive(Debug, Clone, Copy, ValueEnum)]
+pub enum GraphDirection {
+    /// Left to right
+    Lr,
+    /// Top to bottom
+    Tb,
+}
+
+impl fmt::Display for GraphDirection {
+    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
+        match self {
+            Self::Lr => write!(f, "LR"),
+            Self::Tb => write!(f, "TB"),
+        }
+    }
+}
