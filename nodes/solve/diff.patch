+        (uncert1 / data1) ** 2
+        + (uncert2 / data2) ** 2
+        + (2 * cor * np.abs(uncert1 * uncert2) / (data1 * data2))
+    )
+    assert_array_almost_equal(nd3.uncertainty.array, ref_uncertainty)
+
+    nd3 = nd1.divide(nd2, uncertainty_correlation=cor)
+    nd4 = nd2.divide(nd1, uncertainty_correlation=cor)
