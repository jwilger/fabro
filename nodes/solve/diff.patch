+def test_arithmetics_stddevuncertainty_basic():
+    nd1 = NDDataArithmetic([1, 2, 3], uncertainty=StdDevUncertainty([1, 1, 3]))
+    nd2 = NDDataArithmetic([2, 2, 2], uncertainty=StdDevUncertainty([2, 2, 2]))
+    nd3 = nd1.add(nd2)
+    nd4 = nd2.add(nd1)
