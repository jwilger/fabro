+        + (uncert2 / data2) ** 2
+        - (2 * cor * np.abs(uncert1 * uncert2) / (data1 * data2))
+    )
+    assert_array_almost_equal(nd3.uncertainty.array, ref_uncertainty_1)
+    ref_uncertainty_2 = (np.abs(data2 / data1)) * np.sqrt(
